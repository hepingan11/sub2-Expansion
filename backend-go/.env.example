SERVER_PORT=8625

DB_URL=postgres://postgres:postgres@localhost:5432/redeem_code_system?sslmode=disable&TimeZone=Asia/Shanghai
DB_USERNAME=postgres
DB_PASSWORD=postgres

# 如果填写 DB_DSN，会优先使用它并忽略上面的 DB_URL/DB_USERNAME/DB_PASSWORD。
# DB_DSN=host=localhost user=postgres password=postgres dbname=redeem_code_system port=5432 sslmode=disable TimeZone=Asia/Shanghai

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
AUTH_TOKEN_TTL_HOURS=12
CORS_ALLOWED_ORIGINS=http://localhost:5173
CHECK_IN_DAILY_MAX_USERS=20

# 签到时自动调用 Sub2API 生成对应金额的 balance 兑换码。
SUB2API_BASE_URL=https://your-sub2api-host

# 默认认证方式会按已配置项推断；后台页面可覆盖为 admin_api_key 或 password。
SUB2API_ADMIN_API_KEY=
# 未配置管理员 API Key 时，也可以配置管理员账号密码，后端会自动登录获取 access_token。
SUB2API_ADMIN_EMAIL=admin@example.com
SUB2API_ADMIN_PASSWORD=
SUB2API_TIMEOUT_SECONDS=15

# 使用管理员账号密码认证时，后台会定时预热/刷新 access_token，并保存到 system_settings。
SUB2API_TOKEN_REFRESH_ENABLED=true
SUB2API_TOKEN_REFRESH_INTERVAL_SECONDS=300
