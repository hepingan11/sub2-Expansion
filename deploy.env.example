# Copy this file to .env before production deployment, then change the secrets.

HTTP_PORT=6779
# Use an absolute host path if SYSTEM_UPDATE_COMMAND is enabled.
PROJECT_DIR=.
TZ=Asia/Shanghai

POSTGRES_DB=sub2_expansion
POSTGRES_USER=sub2_expansion
POSTGRES_PASSWORD=change-me-sub2-expansion

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
AUTH_SECRET=please-change-this-secret-before-production
AUTH_TOKEN_TTL_HOURS=24
APP_VERSION=v0.2
GITHUB_REPOSITORY=hepingan11/sub2-Expansion
# Docker deployment automatically uses scripts/update.sh. Set false to disable the admin update button.
SYSTEM_UPDATE_ENABLED=true
# Optional override. Leave empty to use the built-in update script.
SYSTEM_UPDATE_COMMAND=

# If users access through a domain, keep VITE_API_BASE empty and let Nginx proxy /api.
VITE_API_BASE=
CORS_ALLOWED_ORIGINS=*
# Optional absolute frontend URL returned when social check-in requires account binding.
# Leave empty when frontend and backend are served from the same public host.
FRONTEND_PUBLIC_URL=

CHECK_IN_DAILY_MAX_USERS=20

SUB2API_BASE_URL=
SUB2API_ADMIN_API_KEY=
SUB2API_ADMIN_EMAIL=
SUB2API_ADMIN_PASSWORD=
SUB2API_TIMEOUT_SECONDS=15
SUB2API_TOKEN_REFRESH_ENABLED=true
SUB2API_TOKEN_REFRESH_INTERVAL_SECONDS=300

# Telegram Bot 长轮询接入。Token 请用 BotFather 生成，不要提交到仓库。
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_POLL_INTERVAL_SECONDS=2
